# ============================================================
# 环境变量配置模板
# 使用方式：cp .env.example .env  然后编辑 .env 填入真实值
# ============================================================

# --- MySQL 数据库 ---
MYSQL_ROOT_PASSWORD=root123
MYSQL_DATABASE=qa_platform
MYSQL_USER=qa_user
MYSQL_PASSWORD=qa_pass123

# --- AI 大模型 (OpenAI 兼容协议) ---
AI_API_KEY=sk-your-api-key-here
AI_BASE_URL=https://api.openai.com
AI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-ada-002

# --- 服务端口 (可自定义) ---
BACKEND_PORT=8080
FRONTEND_PORT=3000
CHROMADB_PORT=8000

# --- Python 微调服务 ---
PYTHON_TRAIN_URL=http://python-train:8002
